rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    /** Same emails as rbac/config.adminEmails in Console (lowercase recommended). */
    function isListedEmailAdmin() {
      return isSignedIn()
        && request.auth.token.email != null
        && exists(/databases/$(database)/documents/rbac/config)
        && request.auth.token.email in get(/databases/$(database)/documents/rbac/config).data.adminEmails;
    }

    function isUidAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isAdmin() {
      return isUidAdmin() || isListedEmailAdmin();
    }

    match /rbac/config {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /admins/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow write: if false;
    }

    match /admin_data/{document=**} {
      allow read, write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
